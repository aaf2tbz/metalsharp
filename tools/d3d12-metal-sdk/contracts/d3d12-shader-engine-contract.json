{
  "schema": "metalsharp.d3d12.shader-engine.v1",
  "summary": {
    "name": "M12 D3D12 shader engine",
    "purpose": "Define the DXBC/DXIL to Metal shader engine as one reviewed system covering parsing, lowering, binding manifests, PSO creation, cache behavior, runtime binding, offline replay, and probe gates.",
    "status": "active",
    "reported_shader_model": "6.5"
  },
  "source_surfaces": [
    {
      "id": "dxil-container",
      "title": "DXIL container and bitcode intake",
      "paths": [
        "vendor/dxmt/src/airconv/dxil/dxil_container.cpp",
        "vendor/dxmt/src/airconv/dxil/llvm_bitcode.cpp",
        "vendor/dxmt/src/airconv/dxil/dxil_ir.cpp"
      ],
      "must_contain": [
        "DXILContainer::parse",
        "BitcodeReader::parse",
        "DXILIRBuilder::build"
      ]
    },
    {
      "id": "dxil-msl-lowering",
      "title": "Typed DXIL to MSL lowering",
      "paths": [
        "vendor/dxmt/src/airconv/dxil/msl_lowering.cpp",
        "vendor/dxmt/src/airconv/dxil/msl_lowering.hpp",
        "vendor/dxmt/src/airconv/dxil/dxil_to_msl.cpp"
      ],
      "must_contain": [
        "MSLLowering::lower",
        "metalsharp.binding_manifest.v1",
        "DXOP_CreateHandle",
        "DXOP_CreateHandleFromBinding"
      ]
    },
    {
      "id": "shader-compiler",
      "title": "D3D12 shader compiler frontend",
      "paths": [
        "vendor/dxmt/src/d3d12/d3d12_shader_compiler.cpp",
        "vendor/dxmt/src/d3d12/d3d12_shader_compiler.hpp"
      ],
      "must_contain": [
        "D3D12ShaderCompiler",
        "MSLLowering"
      ]
    },
    {
      "id": "pso-build",
      "title": "Graphics and compute PSO construction",
      "paths": [
        "vendor/dxmt/src/d3d12/d3d12_device.cpp",
        "vendor/dxmt/src/d3d12/d3d12_pipeline_state.cpp",
        "vendor/dxmt/src/d3d12/d3d12_pipeline_state.hpp"
      ],
      "must_contain": [
        "CreateGraphicsPipelineState",
        "CreateComputePipelineState",
        "MTLD3D12PipelineState"
      ]
    },
    {
      "id": "runtime-binding",
      "title": "Root descriptor, draw, and present-time binding",
      "paths": [
        "vendor/dxmt/src/d3d12/d3d12_command_list.cpp",
        "vendor/dxmt/src/d3d12/d3d12_command_queue.cpp",
        "vendor/dxmt/src/d3d12/d3d12_binding_completeness.hpp",
        "vendor/dxmt/src/d3d12/d3d12_command_stats.hpp"
      ],
      "must_contain": [
        "DrawInstanced",
        "DrawIndexedInstanced",
        "binding_completeness",
        "shader"
      ]
    },
    {
      "id": "shader-cache",
      "title": "Shader cache and cache invalidation surface",
      "paths": [
        "vendor/dxmt/src/dxmt/dxmt_shader_cache.cpp",
        "vendor/dxmt/src/dxmt/dxmt_shader_cache.hpp",
        "vendor/dxmt/src/d3d12/d3d12_trace.hpp"
      ],
      "must_contain": [
        "shader_cache",
        "DXMT_SHADER_CACHE_PATH",
        "DXMT_D3D12_TRACE"
      ]
    }
  ],
  "offline_gates": [
    {
      "id": "native-dxil-converter",
      "command": "ninja -C vendor/dxmt/build-metalsharp-x64-tests tests/test_dxil_converter && vendor/dxmt/build-metalsharp-x64-tests/tests/test_dxil_converter <shader-cache>",
      "proves": "DXBC/DXIL containers parse and lower through the typed MSL path, including targeted game-corpus regressions."
    },
    {
      "id": "binding-manifest-audit",
      "command": "python3 tools/d3d12-metal-sdk/scripts/dxil-binding-manifest-audit.py --msl-dir <generated-msl> --markdown <out.md>",
      "proves": "Every generated MSL shader declares direct buffer, texture, sampler, and descriptor-range surfaces."
    },
    {
      "id": "root-signature-audit",
      "command": "python3 tools/d3d12-metal-sdk/scripts/dxil-root-signature-audit.py --corpus <shader-cache> --markdown <out.md>",
      "proves": "Typed binding manifests are covered by captured D3D12 root signatures."
    },
    {
      "id": "graphics-pso-audit",
      "command": "python3 tools/d3d12-metal-sdk/scripts/d3d12-graphics-pso-audit.py --corpus <shader-cache>",
      "proves": "Graphics PSO manifests contain valid vertex, fragment, topology, render-target, depth, and shader metadata."
    },
    {
      "id": "compute-pso-audit",
      "command": "python3 tools/d3d12-metal-sdk/scripts/d3d12-compute-pso-audit.py --corpus <shader-cache>",
      "proves": "Compute PSO manifests contain valid compute shader, threadgroup, and unsupported-DXIL diagnostics."
    },
    {
      "id": "shader-corpus-replay",
      "command": "python3 tools/d3d12-metal-sdk/scripts/replay-shader-corpus.py --corpus <shader-cache>",
      "proves": "Captured DXBC/DXIL blobs replay through the converter and produce reusable shader artifacts."
    },
    {
      "id": "m12-render-check",
      "command": "tools/ci/m12-check.sh",
      "proves": "A live DX12 render path can create PSOs, bind shaders, draw indexed geometry, present, and read back expected pixels."
    }
  ],
  "runtime_artifacts": [
    "d3d12.dll",
    "dxgi.dll",
    "winemetal.dll",
    "winemetal.so"
  ],
  "evidence": [
    {
      "kind": "source",
      "path": "vendor/dxmt/src/airconv/dxil/msl_lowering.cpp",
      "note": "Primary typed DXIL-to-MSL lowering and binding manifest emission."
    },
    {
      "kind": "source",
      "path": "vendor/dxmt/src/d3d12/d3d12_pipeline_state.cpp",
      "note": "D3D12 PSO to Metal pipeline-state construction."
    },
    {
      "kind": "test",
      "path": "vendor/dxmt/tests/dxil/test_dxil_converter.cpp",
      "note": "Native offline DXIL converter corpus and targeted regression gate."
    },
    {
      "kind": "probe",
      "path": "tools/ci/m12-check.sh",
      "note": "CI-oriented M12 live render pipeline proof."
    }
  ]
}
