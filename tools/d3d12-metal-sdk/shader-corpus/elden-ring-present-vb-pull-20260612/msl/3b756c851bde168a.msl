) {
  float4 result = float4(0,0,0,1);
  int v0 = 0; // unresolved value pre-decl
  int v1 = 0; // unresolved value pre-decl
  int v2 = 0; // unresolved value pre-decl
  float v34 = in.v0.x;
  float v35 = in.v0.y;
  float v37 = (tex3.sample(samp3, float2(v34, v35))).x;
  float v38 = (tex3.sample(samp3, float2(v34, v35))).y;
  float v39 = (tex3.sample(samp3, float2(v34, v35))).z;
  float v41 = (tex3.sample(samp3, float2(v34, v35))).x;
  float v42 = 1.0f - v41;
  float v43 = v42 * v37;
  float v44 = v42 * v38;
  float v45 = v42 * v39;
  result.x = v43;
  result.y = v44;
  result.z = v45;
  result.w = 0.0;
