+
+#pragma GCC diagnostic ignored "-Wdeclaration-after-statement"
+
+static const char *const d3dmetal_client_surface_key = "metalsharp.d3dmetal.client_surface";
+
+/* Associate/extract a D3DMetal client_surface pointer on a content view.
+ * The D3DMetal host shim (metalsharp_d3dmetal.c) sets this when it creates a
+ * client surface so that WineMetalLayer-nextDrawable can find it and post the
+ * CLIENT_SURFACE_PRESENTED event. Declared in macdrv_cocoa.h (Cocoa API); kept
+ * default-visibility so the host-ABI surface is grep-discoverable. */
+__attribute__((visibility("default")))
+void macdrv_set_view_d3dmetal_client_surface(macdrv_view v, void *client_surface)
+{
+    objc_setAssociatedObject((id)v, d3dmetal_client_surface_key, [NSNumber numberWithPointer:client_surface], OBJC_ASSOCIATION_RETAIN);
+}
+
+__attribute__((visibility("default")))
+void *macdrv_get_view_d3dmetal_client_surface(macdrv_view v)
+{
+    NSNumber *n = objc_getAssociatedObject((id)v, d3dmetal_client_surface_key);
+    return n ? [n pointerValue] : NULL;
+}
+
+@implementation WineMetalLayer
+
+    /* Extend [CAMetalLayer nextDrawable] so client_surface_present() is called
+     * for the D3DMetal client_surface associated with the view that owns this
+     * layer. The layer's delegate is the WineMetalView containing it; that
+     * view's superview is the WineContentView on which the client_surface was
+     * associated by macdrv_set_view_d3dmetal_client_surface().
+     */
+    - (id<CAMetalDrawable>) nextDrawable
+    {
+        if ([self.delegate isKindOfClass:NSClassFromString(@"WineMetalView")])
+        {
+            NSView *view = (NSView *)self.delegate;
+            if ([view.superview isKindOfClass:NSClassFromString(@"WineContentView")] &&
+                [view.window isKindOfClass:NSClassFromString(@"WineWindow")])
+            {
+                void *client_surface = macdrv_get_view_d3dmetal_client_surface((macdrv_view)view.superview);
+                if (client_surface)
+                {
+                    macdrv_event *event;
+                    event = macdrv_create_event(CLIENT_SURFACE_PRESENTED, (WineWindow *)view.window);
+                    event->client_surface_presented.client_surface = client_surface;
+
+                    WineEventQueue *queue = [(WineWindow *)view.window queue];
+                    [queue postEvent:event];
+                    macdrv_release_event(event);
+                }
+            }
+        }
+
+        return [super nextDrawable];
+    }
+
+@end
+
+#endif
