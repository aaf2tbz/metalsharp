/* Registry/display thunk callback targets. These are UINT64 PE-side callback
 * pointers set during macdrv init; until the PE-side callbacks are wired up
 * (Phase 6 launch), they remain 0 and KeUserDispatchCallback returns
 * STATUS_ENTRYPOINT_NOT_FOUND, so the thunks fail gracefully. The Unix-side
 * host ABI contract (the macdrv_functions table) is correct regardless. */
UINT64 regcreateopenkeyexa_callback;
UINT64 regqueryvalueexa_callback;
UINT64 regsetvalueexa_callback;

/* Dispatch parameter layouts for the registry thunks (match the PE-side
 * callback contract; self-contained here because upstream unixlib.h does not
 * carry these D3DMetal-specific structs). */
struct regcreateopenkeyexa_params
{
    struct dispatch_callback_params dispatch;
    UINT32 create;
    UINT32 hkey;
    UINT64 name;
    UINT32 reserved;
    UINT64 class;
    UINT32 options;
    UINT32 access;
    UINT64 security;
    UINT64 retkey;
    UINT64 disposition;
    UINT32 result;
};

struct regqueryvalueexa_params
{
    struct dispatch_callback_params dispatch;
    UINT32 hkey;
    UINT64 name;
    UINT64 reserved;
    UINT64 type;
    UINT64 data;
    UINT64 count;
    UINT32 result;
};

struct regsetvalueexa_params
{
    struct dispatch_callback_params dispatch;
    UINT32 hkey;
    UINT64 name;
    UINT32 reserved;
    UINT32 type;
    UINT64 data;
    UINT32 count;
    UINT32 result;
};

