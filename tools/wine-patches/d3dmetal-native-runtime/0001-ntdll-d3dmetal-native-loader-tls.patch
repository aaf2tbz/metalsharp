  *
  * Build the module data for a mapped dll.
  */
+static BOOL d3dmetal_native_enabled(void)
+{
+    static const WCHAR env_name[] = L"MS_ACTIVE_GRAPHICS_BACKEND";
+    static const WCHAR backend_name[] = L"d3dmetal_native";
+    WCHAR buffer[64];
+    UNICODE_STRING name, value, expected;
+
+    RtlInitUnicodeString( &name, env_name );
+    value.Buffer = buffer;
+    value.Length = 0;
+    value.MaximumLength = sizeof(buffer);
+    if (RtlQueryEnvironmentVariable_U( NULL, &name, &value )) return FALSE;
+
+    RtlInitUnicodeString( &expected, backend_name );
+    return RtlEqualUnicodeString( &value, &expected, TRUE );
+}
+
+static BOOL is_d3dmetal_bridge_module( const UNICODE_STRING *base_name )
+{
+    static const WCHAR d3d10W[] = L"d3d10.dll";
+    static const WCHAR d3d11W[] = L"d3d11.dll";
+    static const WCHAR d3d12W[] = L"d3d12.dll";
+    static const WCHAR dxgiW[] = L"dxgi.dll";
+    static const WCHAR nvapi64W[] = L"nvapi64.dll";
+    static const WCHAR nvngxW[] = L"nvngx-on-metalfx.dll";
+    UNICODE_STRING name;
+
+    RtlInitUnicodeString( &name, d3d10W );
+    if (RtlEqualUnicodeString( base_name, &name, TRUE )) return TRUE;
+    RtlInitUnicodeString( &name, d3d11W );
+    if (RtlEqualUnicodeString( base_name, &name, TRUE )) return TRUE;
+    RtlInitUnicodeString( &name, d3d12W );
+    if (RtlEqualUnicodeString( base_name, &name, TRUE )) return TRUE;
+    RtlInitUnicodeString( &name, dxgiW );
+    if (RtlEqualUnicodeString( base_name, &name, TRUE )) return TRUE;
+    RtlInitUnicodeString( &name, nvapi64W );
+    if (RtlEqualUnicodeString( base_name, &name, TRUE )) return TRUE;
+    RtlInitUnicodeString( &name, nvngxW );
+    return RtlEqualUnicodeString( base_name, &name, TRUE );
+}
+
+static void make_d3dmetal_bridge_image_writable( WINE_MODREF *wm, void *module, SIZE_T map_size )
+{
+    void *addr = module;
+    SIZE_T size = map_size;
+    ULONG old_prot;
+    NTSTATUS status;
+
+    if (!d3dmetal_native_enabled()) return;
+    if (!is_d3dmetal_bridge_module( &wm->ldr.BaseDllName )) return;
+
+    status = NtProtectVirtualMemory( NtCurrentProcess(), &addr, &size, PAGE_EXECUTE_READWRITE, &old_prot );
+    if (status) WARN( "Failed to make D3DMetal bridge %s writable, status %#lx.\n",
+                      debugstr_w(wm->ldr.BaseDllName.Buffer), status );
+    else TRACE( "Made D3DMetal bridge %s writable at %p-0x%Ix (old %#lx).\n",
+                debugstr_w(wm->ldr.BaseDllName.Buffer), addr, size, old_prot );
+}
