+void apple_restore_pthread_slots( TEB *teb )
+{
+    struct amd64_thread_data *thread_data = (struct amd64_thread_data *)&teb->GdiTebBatch;
+    char *pthread_teb = thread_data->pthread_teb;
+
+    if (!pthread_teb) return;
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, Tib.Self)) = thread_data->pthread_slot_self;
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, ThreadLocalStoragePointer)) = thread_data->pthread_slot_tls;
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, Peb)) = thread_data->pthread_slot_peb;
 }
+
+void apple_mirror_teb_slots( TEB *teb )
+{
+    struct amd64_thread_data *thread_data = (struct amd64_thread_data *)&teb->GdiTebBatch;
+    char *pthread_teb = thread_data->pthread_teb;
+
+    if (!pthread_teb) return;
+    thread_data->pthread_slot_self = *(void **)(pthread_teb + FIELD_OFFSET(TEB, Tib.Self));
+    thread_data->pthread_slot_tls  = *(void **)(pthread_teb + FIELD_OFFSET(TEB, ThreadLocalStoragePointer));
+    thread_data->pthread_slot_peb  = *(void **)(pthread_teb + FIELD_OFFSET(TEB, Peb));
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, Tib.Self)) = teb->Tib.Self;
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, ThreadLocalStoragePointer)) = teb->ThreadLocalStoragePointer;
+    *(void **)(pthread_teb + FIELD_OFFSET(TEB, Peb)) = teb->Peb;
+}
 #endif
 
