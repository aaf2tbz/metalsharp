+static char *get_d3dmetal_payload_dir(void)
+{
+    const char *payload = getenv( "MS_D3DMETAL_PAYLOAD_DIR" );
+    const char *shared;
+    char *copy, *slash;
+
+    if (payload && *payload) return strdup( payload );
+
+    /* Derive <payload> from MS_D3DMETAL_SHARED_PATH=<payload>/external/libd3dshared.dylib. */
+    shared = getenv( "MS_D3DMETAL_SHARED_PATH" );
+    if (!shared || !*shared) return NULL;
+
+    if (!(copy = strdup( shared ))) return NULL;
+    if (!(slash = strrchr( copy, '/' ))) goto failed;
+    *slash = 0;
+    if (!(slash = strrchr( copy, '/' ))) goto failed;
+    *slash = 0;
+    return copy;
+
+failed:
+    free( copy );
+    return NULL;
+}
