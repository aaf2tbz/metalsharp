+/* MetalSharp D3DMetal loader compatibility shim.
+ *
+ * GPTK4's libd3dshared.dylib can expose Rosetta/non-native code region helpers.
+ * Keep this Darwin-only, MetalSharp-env-gated, and independent of syscall/TLS paths.
  */
+#ifdef __APPLE__
+static pthread_once_t ms_d3dmetal_shared_once = PTHREAD_ONCE_INIT;
+static void *ms_d3dmetal_shared_lib;
+static void (*ms_register_non_native_code_region)( void *, void * );
+static BOOL (*ms_supports_non_native_code_regions)( void );
+
+static BOOL ms_d3dmetal_sonoma_or_later(void)
+{
+    struct utsname name;
+    int major;
+    if (uname(&name)) return FALSE;
+    major = atoi(name.release);
+    return major >= 23;  /* macOS 14 (Sonoma) is Darwin 23 */
+}
+
+static void ms_d3dmetal_init_shared_support(void)
+{
+    const char *path = getenv("MS_D3DMETAL_SHARED_PATH");
+    if (!d3dmetal_native_enabled_unix() || !path || !ms_d3dmetal_sonoma_or_later()) return;
+
+    ms_d3dmetal_shared_lib = dlopen(path, RTLD_NOW | RTLD_LOCAL);
+    if (ms_d3dmetal_shared_lib)
+    {
+        ms_register_non_native_code_region = dlsym(ms_d3dmetal_shared_lib, "register_non_native_code_region");
+        ms_supports_non_native_code_regions = dlsym(ms_d3dmetal_shared_lib, "supports_non_native_code_regions");
+        TRACE("Loaded libd3dshared.dylib from MS_D3DMETAL_SHARED_PATH (%s): "
+              "non-native code region support %s\n", path,
+              (ms_register_non_native_code_region && ms_supports_non_native_code_regions &&
+               ms_supports_non_native_code_regions()) ? "present" : "absent");
+    }
+    else
+        TRACE("Loading libd3dshared.dylib failed: %s\n", dlerror());
+}
+#endif
+
+static NTSTATUS pe_module_loaded( void *args )
+{
+#ifdef __APPLE__
+    struct pe_module_loaded_params *params = args;
+
+    pthread_once(&ms_d3dmetal_shared_once, ms_d3dmetal_init_shared_support);
+    if (ms_register_non_native_code_region && ms_supports_non_native_code_regions &&
+        ms_supports_non_native_code_regions())
+    {
+        TRACE("Marking MetalSharp non-native code region: %p-%p\n", params->start, params->end);
+        ms_register_non_native_code_region(params->start, params->end);
+    }
+#endif
+    return STATUS_SUCCESS;
+}
+
 DECLSPEC_EXPORT void __wine_main( int argc, char *argv[] )
 {
     main_argc = argc;
     main_argv = argv;
 
     init_paths();
+#ifdef __APPLE__
+    pthread_once(&ms_d3dmetal_shared_once, ms_d3dmetal_init_shared_support);
+#endif
     if (!getenv( "WINELOADERNOEXEC" ) || argc <= 1) check_command_line( argc, argv );
     unsetenv( "WINELOADERNOEXEC" );
 
