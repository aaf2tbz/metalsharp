{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetalSharp Electron to backend contract",
  "contract_version": "1",
  "description": "The implementation-independent HTTP boundary used by Electron and the shipped backend. A breaking change requires a new contract version and fixtures before it can be packaged.",
  "status": {
    "path": "/status",
    "method": "GET",
    "required": [
      "ok",
      "version",
      "pid",
      "metalsharp_home"
    ],
    "contract_version_field": "contract_version",
    "legacy_versions": {
      "0.54.5": "1",
      "0.55.0": "1",
      "0.55.1": "1"
    }
  },
  "conformance_routes": [
    {
      "name": "setup",
      "method": "GET",
      "path": "/setup/state",
      "status": 200,
      "required": [
        "ok",
        "completed",
        "step",
        "steamApiKeySet"
      ]
    },
    {
      "name": "steam-status",
      "method": "GET",
      "path": "/steam/status",
      "status": 200,
      "required": [
        "installed",
        "running"
      ]
    },
    {
      "name": "steam-library",
      "method": "GET",
      "path": "/steam/library",
      "status": 200,
      "required": [
        "ok",
        "games",
        "total"
      ]
    },
    {
      "name": "bottles",
      "method": "GET",
      "path": "/bottles",
      "status": 200,
      "required": [
        "ok",
        "bottles"
      ]
    },
    {
      "name": "bottle-profiles",
      "method": "GET",
      "path": "/bottles/profiles",
      "status": 200,
      "required": [
        "ok",
        "profiles"
      ]
    },
    {
      "name": "bottle-redist-sources",
      "method": "GET",
      "path": "/bottles/redist-sources",
      "status": 200,
      "required": [
        "ok",
        "sources"
      ]
    },
    {
      "name": "bottle-repair-rejection",
      "method": "POST",
      "path": "/bottles/repair-component",
      "request_body": {
        "id": "contract-missing-bottle",
        "component": "agility_sdk"
      },
      "status": 200,
      "required": [
        "ok",
        "error"
      ]
    },
    {
      "name": "sharp-library",
      "method": "GET",
      "path": "/sharp-library",
      "status": 200,
      "required": [
        "ok",
        "apps"
      ]
    },
    {
      "name": "sharp-library-launch-rejection",
      "method": "POST",
      "path": "/sharp-library/launch",
      "request_body": {
        "id": "contract-missing-app"
      },
      "status": 200,
      "required": [
        "ok",
        "error"
      ]
    },
    {
      "name": "gog-status",
      "method": "GET",
      "path": "/sharp-library/gog/status",
      "status": 200,
      "required": [
        "ok",
        "status"
      ]
    },
    {
      "name": "gog-games",
      "method": "GET",
      "path": "/sharp-library/gog/games",
      "status": 200,
      "required": [
        "ok",
        "games",
        "status"
      ]
    },
    {
      "name": "gog-play-rejection",
      "method": "POST",
      "path": "/sharp-library/gog/play",
      "request_body": {
        "productId": ""
      },
      "status": 200,
      "required": [
        "ok",
        "error"
      ]
    },
    {
      "name": "cache-size",
      "method": "GET",
      "path": "/cache/size",
      "status": 200,
      "required": [
        "ok",
        "shader_cache",
        "pipeline_cache"
      ]
    },
    {
      "name": "setup-device-name",
      "method": "GET",
      "path": "/setup/device-name",
      "status": 200,
      "required": [
        "ok",
        "name"
      ]
    },
    {
      "name": "logs",
      "method": "GET",
      "path": "/logs",
      "status": 200,
      "required": [
        "ok",
        "logs"
      ]
    },
    {
      "name": "crash-reports",
      "method": "GET",
      "path": "/logs/crash-reports",
      "status": 200,
      "required": [
        "ok",
        "reports"
      ]
    },
    {
      "name": "log-stream",
      "method": "GET",
      "path": "/logs/stream?after=0",
      "status": 200,
      "required": [
        "ok",
        "lines",
        "total"
      ]
    },
    {
      "name": "pipeline-dry-run",
      "method": "GET",
      "path": "/diagnostics/pipeline/dry-run?appid=0",
      "status": 200,
      "required": [
        "appid",
        "dry_run",
        "env_pairs"
      ]
    },
    {
      "name": "m12-dry-run",
      "method": "GET",
      "path": "/diagnostics/m12/dry-run?appid=0",
      "status": 200,
      "required": [
        "appid",
        "dry_run",
        "env_pairs"
      ]
    }
  ],
  "typed_routes": {
    "GET /status": {
      "response": "BackendStatus"
    },
    "GET /setup/state": {
      "response": "SetupState"
    },
    "GET /steam/status": {
      "response": "SteamStatus"
    },
    "GET /steam/library": {
      "response": "SteamLibrary"
    },
    "GET /bottles": {
      "response": "BottleList"
    },
    "GET /logs": {
      "response": "LogList"
    },
    "GET /logs/stream": {
      "response": "LogStream"
    },
    "GET /diagnostics/pipeline/dry-run": {
      "response": "PipelineDryRun"
    },
    "GET /diagnostics/m12/dry-run": {
      "response": "PipelineDryRun"
    },
    "POST /game/launch-auto": {
      "request": "LaunchAutoRequest",
      "response": "LaunchResult",
      "process_launch": true
    }
  },
