{
  "name": "metalsharp",
  "version": "0.1.0",
  "description": "MetalSharp — D3D→Metal translation layer frontend",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && npm run copy-html",
    "copy-html": "cp src/renderer/index.html dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "tsc -w & electron .",
    "rust:build": "cd src-rust && cargo build --release",
    "rust:dev": "cd src-rust && cargo build",
    "build:all": "npm run rust:build && npm run build"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
