{
  "name": "metalsharp",
  "version": "0.3.0",
  "description": "MetalSharp — D3D→Metal translation layer frontend",
  "author": "MetalSharp",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaf2tbz/metalsharp.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && npm run copy-renderer-assets",
    "copy-renderer-assets": "mkdir -p dist/renderer && cp src/renderer/index.html src/renderer/styles.css src/renderer/icon.png src/renderer/pressstart2p.ttf dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "tsc -w & electron .",
    "rust:build": "cd src-rust && cargo build --release",
    "rust:dev": "cd src-rust && cargo build",
    "build:all": "npm run rust:build && npm run build",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "dmg": "npm run dist -- --mac dmg"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "build": {
    "appId": "com.metalsharp.app",
    "productName": "MetalSharp",
    "copyright": "Copyright © 2026 MetalSharp",
    "mac": {
      "category": "public.app-category.games",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "minimumSystemVersion": "13.0.0",
      "protocols": [
        {
          "name": "MetalSharp Game",
          "schemes": [
            "metalsharp"
          ]
        }
      ]
    },
    "dmg": {
      "iconSize": 120,
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src-rust/target/release/metalsharp-backend",
        "to": "metalsharp-backend"
      },
      {
        "from": "native/metalsharp",
        "to": "metalsharp"
      },
      {
        "from": "native/metalsharp_launcher",
        "to": "metalsharp_launcher"
      },
      {
        "from": "native/d3d11.dylib",
        "to": "d3d11.dylib"
      },
      {
        "from": "native/d3d12.dylib",
        "to": "d3d12.dylib"
      },
      {
        "from": "native/dxgi.dylib",
        "to": "dxgi.dylib"
      },
      {
        "from": "native/xaudio2_9.dylib",
        "to": "xaudio2_9.dylib"
      },
      {
        "from": "native/xinput1_4.dylib",
        "to": "xinput1_4.dylib"
      }
    ],
    "directories": {
      "output": "../dist/electron"
    }
  }
}
