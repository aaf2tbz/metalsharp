#!/usr/bin/env bash
# Pre-commit hook for the MetalSharp repo.
#
# Run quick local checks before allowing a commit. Skip with `git commit --no-verify`.
#
# Policy: this hook FAILS HARD if a check is required but the toolchain
# needed to run it is missing. The whole point is to prevent the same
# "tool missing locally" surprises that motivated these checks.
#
# Install with:
#   ln -s ../../.github/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or run the helper:
#   ./install.sh install-hooks

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# Resolve all files that are about to be committed
STAGED=()
while IFS= read -r line; do
    [ -n "$line" ] && STAGED+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ ${#STAGED[@]} -eq 0 ]; then
    exit 0
fi

# --- Pre-flight: which toolchains are required? ---

NEED_CLANG_FORMAT=0
NEED_NPM=0
NEED_PYTHON=0

for f in "${STAGED[@]}"; do
    case "$f" in
        *.c|*.cpp|*.h|*.hpp|*.mm|*.m)      NEED_CLANG_FORMAT=1 ;;
        app/*.ts|app/*.tsx|app/*.js|app/*.jsx|app/*.json|app/*.css|app/*.html) NEED_NPM=1 ;;
    esac
done
if printf '%s\n' "${STAGED[@]}" | grep -q '^configs/mtsp-rules.toml$'; then
    NEED_PYTHON=1
fi

# --- Helpers ---

log()  { echo -e "\033[0;36m[pre-commit]\033[0m $*"; }
warn() { echo -e "\033[0;33m[pre-commit]\033[0m $*"; }
fail() { echo -e "\033[0;31m[pre-commit]\033[0m $*" >&2; exit 1; }

# --- Toolchain gate: fail HARD if a check is required but the tool is missing ---

missing=()
[ "$NEED_CLANG_FORMAT" -eq 1 ] && ! command -v clang-format >/dev/null 2>&1 && missing+=("clang-format (required to format C/C++/Obj-C files)")
[ "$NEED_NPM" -eq 1 ] && [ ! -d app/node_modules ] && missing+=("app/node_modules (run 'cd app && npm ci' to install)")
[ "$NEED_PYTHON" -eq 1 ] && ! command -v python3 >/dev/null 2>&1 && missing+=("python3 (required to validate the rules TOML)")

if [ ${#missing[@]} -gt 0 ]; then
    echo "" >&2
    fail "Pre-commit cannot run required checks because tools are missing:"
    for m in "${missing[@]}"; do
        echo "  - $m" >&2
    done
    echo "" >&2
    echo "Install the missing tools, or bypass this hook with 'git commit --no-verify'." >&2
    echo "Bypassing is acceptable but the same failure will surface in CI." >&2
fi

# --- 1. C/C++/Obj-C: clang-format --

if [ "$NEED_CLANG_FORMAT" -eq 1 ]; then
    log "clang-format --dry-run --Werror on staged C/C++/Obj-C files"
    FAILED=0
    for f in "${STAGED[@]}"; do
        case "$f" in
            *.c|*.cpp|*.h|*.hpp|*.mm|*.m)
                if [ -f "$f" ]; then
                    if ! clang-format --dry-run --Werror "$f" >/dev/null 2>&1; then
                        echo "  unformatted: $f"
                        FAILED=1
                    fi
                fi
                ;;
        esac
    done
    [ "$FAILED" -eq 0 ] || fail "clang-format failed; run 'clang-format -i <file>' on the listed files."
fi

# --- 2. TypeScript: tsc, biome, prettier --

if [ "$NEED_NPM" -eq 1 ]; then
    if printf '%s\n' "${STAGED[@]}" | grep -qE '^app/.*\.tsx?$'; then
        log "tsc --noEmit (app)"
        (cd app && npx tsc --noEmit) || fail "tsc failed; fix the TypeScript errors before committing."
    fi

    if printf '%s\n' "${STAGED[@]}" | grep -qE '^app/src/(renderer|main|shared)/.*\.(ts|tsx|js|jsx)$'; then
        log "biome (app)"
        (cd app && npx @biomejs/biome ci src/main src/shared src/renderer 2>/dev/null || npx @biomejs/biome ci src/) || fail "biome failed; run 'cd app && npx @biomejs/biome ci --write' to auto-fix."
    fi

    log "prettier --check on staged app/ files"
    TS_FILES=$(printf '%s\n' "${STAGED[@]}" | grep -E '^app/.*\.(ts|tsx|js|jsx|html|css|json)$' | tr '\n' ' ')
    if [ -n "$TS_FILES" ]; then
        (cd app && npx prettier --check $TS_FILES) || fail "prettier failed; run 'cd app && npx prettier --write $TS_FILES'."
    fi
fi

# --- 4. Rules TOML validation --

if [ "$NEED_PYTHON" -eq 1 ]; then
    log "validating configs/mtsp-rules.toml"
    if ! python3 -c "import toml" 2>/dev/null; then
        pip3 install --user toml >/dev/null 2>&1
    fi
    python3 tools/ci/validate-rules-toml.py || fail "rules TOML validation failed."
fi

# --- 5. ShellCheck on modified shell scripts --

if printf '%s\n' "${STAGED[@]}" | grep -qE '\.sh$'; then
    if command -v shellcheck >/dev/null 2>&1; then
        log "shellcheck on staged shell scripts"
        FAILED=0
        for f in "${STAGED[@]}"; do
            if [[ "$f" == *.sh ]] && [ -f "$f" ]; then
                if ! shellcheck --external-sources --severity=error "$f" >/dev/null 2>&1; then
                    echo "  shellcheck warnings: $f"
                    FAILED=1
                fi
            fi
        done
        [ "$FAILED" -eq 0 ] || fail "shellcheck failed; run 'shellcheck <file>' on the listed files."
    else
        # shellcheck is optional; CI runs it.
        warn "shellcheck not installed; skipping (CI will catch it)"
    fi
fi

# --- 6. Doc freshness (warn-only by design) ---

if printf '%s\n' "${STAGED[@]}" | grep -qE '(\.md$|^AGENTS\.md$|^README\.md$)'; then
    if command -v python3 >/dev/null 2>&1; then
        log "checking doc freshness (warn-only)"
        python3 tools/ci/check-doc-freshness.py || warn "doc freshness warnings above"
    fi
fi

log "all pre-commit checks passed"
