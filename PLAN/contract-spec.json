  "startup_sequence": [
    { "step": 1, "action": "Read METALSHARP_HOME env var (default: $HOME/.metalsharp)" },
    { "step": 2, "action": "Read METALSHARP_PORT env var (default: 0 = OS-assigned)" },
    { "step": 3, "action": "Initialize logger (ISSUE_LOG_COUNTER = 0)" },
    { "step": 4, "action": "Open/create SQLite database at $METALSHARP_HOME/metalsharp.db" },
    { "step": 5, "action": "Initialize keychain access (Security.framework)" },
    { "step": 6, "action": "Initialize code signing verification" },
    { "step": 7, "action": "Start Endpoint Security client (es_new_client, ES_MACH_LOOKUP)" },
    { "step": 8, "action": "Start IPC bridge listener (background thread)" },
    { "step": 9, "action": "Bind HTTP server on 127.0.0.1:PORT" },
    { "step": 10, "action": "Print METALSHARP_PORT=<port> to stdout" },
    { "step": 11, "action": "Register SIGINT/SIGTERM handlers" },
    { "step": 12, "action": "Enter accept loop — for each connection: parse HTTP, dispatch route, respond JSON" }
  ],
  "shutdown_sequence": [
    { "step": 1, "action": "Stop accepting new HTTP connections" },
    { "step": 2, "action": "Drain in-flight requests (5s timeout)" },
    { "step": 3, "action": "Kill running game processes" },
    { "step": 4, "action": "Stop IPC bridge listener" },
    { "step": 5, "action": "Stop Endpoint Security client" },
    { "step": 6, "action": "Close SQLite database" },
    { "step": 7, "action": "exit(0)" }
  ],
